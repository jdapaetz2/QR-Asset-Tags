# Copy to .env.local and fill in. NEVER commit real secrets.
# See docs/CODE_HANDOFF.md "Environment variables".

# Supabase (public — safe in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (SERVER ONLY — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used to build permanent QR URLs (the /t/{short_code} host)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Storage bucket names (match supabase/migrations/0002_storage.sql)
NEXT_PUBLIC_PUBLIC_ASSETS_BUCKET=public-assets
SUBMISSIONS_BUCKET=submissions

# Anti-abuse (used by public submission intake in Sprint 4)
SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=60
SUBMISSION_RATE_LIMIT_MAX=5
SUBMISSION_HONEYPOT_FIELD=company_website

# Salt for hashing scan-event IPs (server only; never store raw IPs)
SCAN_IP_HASH_SALT=
